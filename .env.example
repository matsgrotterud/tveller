# ============================================================
# TvellerOS – miljøvariabler
# Kopier til .env.local og fyll inn verdier.
# Appen kjører fullt ut i demo-modus uten noen av disse nøklene.
# ============================================================

# ----- APP -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TvellerOS
NODE_ENV=development

# ----- DATABASE (Supabase/Postgres) -----
DATABASE_URL=postgresql://user:password@host:5432/tvelleros
DIRECT_URL=postgresql://user:password@host:5432/tvelleros
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- AUTH -----
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
DEMO_MODE=true

# ----- LAGRING -----
STORAGE_PROVIDER=mock # mock | s3 | supabase
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=eu-north-1
S3_ENDPOINT=

# ----- STRIPE -----
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_PORTFOLIO=

# ----- E-POST -----
EMAIL_PROVIDER=mock # mock | resend | postmark | sendgrid
RESEND_API_KEY=
POSTMARK_API_KEY=
SENDGRID_API_KEY=
FROM_EMAIL=hei@tveller.no

# ----- SMS -----
SMS_PROVIDER=mock # mock | link_mobility | twilio
SMS_API_KEY=
SMS_SENDER=TvellerOS
LINK_MOBILITY_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ----- AI -----
AI_PROVIDER=mock # mock | openai
OPENAI_API_KEY=
AI_MODEL=gpt-4o
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_DATA_PROCESSING_MODE=no_training

# ----- BANKID / VIPPS -----
BANKID_CLIENT_ID=
BANKID_CLIENT_SECRET=
VIPPS_CLIENT_ID=
VIPPS_CLIENT_SECRET=
VIPPS_SUBSCRIPTION_KEY=

# ----- KART / KALENDER -----
MAPS_API_KEY=
CALENDAR_PROVIDER=mock

# ----- WEBHOOKS -----
WEBHOOK_SECRET=

# ----- OBSERVABILITET -----
SENTRY_DSN=
LOG_LEVEL=info

# ----- ØKONOMI-INTEGRASJONER -----
TRIPLETEX_CLIENT_ID=
TRIPLETEX_CLIENT_SECRET=
VISMA_CLIENT_ID=
VISMA_CLIENT_SECRET=
POWEROFFICE_CLIENT_ID=
POWEROFFICE_CLIENT_SECRET=
